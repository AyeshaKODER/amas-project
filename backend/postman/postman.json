            ],
            "url": "{{base_url}}/run",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"Example async workflow\",\n  \"requirements\": [],\n  \"constraints\": {\n    \"use_openai\": false\n  }\n}"
            },
            "description": "Implemented in app/api.py. Enqueues coordinator workflow and returns task_id immediately."
          },
          "response": []
