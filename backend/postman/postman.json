      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "POST /agents/create (register agent record only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/agents/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Planner1\",\n  \"role\": \"planner\",\n  \"metadata\": {}\n}"
            },
            "description": "Implemented in app/api.py. Registers an agent via AgentRegistry.get_or_create. Does not spawn a Docker container."
          },
          "response": []
        },
        {
          "name": "POST /agents/spawn (spawn agent container + register)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const j = pm.response.json();",
                  "pm.expect(j).to.have.property('spawned');",
                  "pm.expect(j.spawned).to.have.property('agent_id');",
                  "if (j.spawned.agent_id) pm.environment.set('agent_id', j.spawned.agent_id);",
                  "if (j.spawned.container_id) pm.environment.set('agent_container_id', j.spawned.container_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/agents/spawn",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AutonomousPlanner\",\n  \"role\": \"planner\",\n  \"image\": \"{{agent_image}}\",\n  \"metadata\": {\n    \"autonomous_loop\": true\n  }\n}"
            },
            "description": "Implemented in app/api.py. Spawns an agent container via AgentSpawner.spawn_agent_container and registers it.\n\nmetadata.autonomous_loop=true triggers AGENT_AUTONOMOUS_LOOP=true inside the spawned agent container (spawner behavior)."
          },
          "response": []
        },
        {
          "name": "GET /agents (list agents)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/agents",
            "description": "Implemented in app/api.py. Lists agents via AgentRegistry.list_agents()."
          },
          "response": []
        },
